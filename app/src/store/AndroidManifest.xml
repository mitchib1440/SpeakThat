<?xml version="1.1" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Store variant: no outbound network access from the app itself -->
    <uses-permission android:name="android.permission.INTERNET" tools:node="remove" />

    <!--
    Store variant permission policy:
    - INTERNET: Removed (privacy-first distribution for F-Droid and similar stores)
    - No auto-updater: Updates handled by app stores
    - No online icons: Uses local fallback icons only
    - Network TTS voices: Handled by the system TTS engine, not this app
    -->

</manifest> 